local _CFG = {}
pcall(function()
    local HttpService = game:GetService("HttpService")
    local content = nil
    if readfile then
        pcall(function() content = readfile("ShadowHUB_Config.json") end)
    end
    if content and content ~= "" then
        local ok, data = pcall(function() return HttpService:JSONDecode(content) end)
        if ok and data then _CFG = data end
    end
end)
local function _cfgGet(key, default)
    if _CFG[key] ~= nil then return _CFG[key] end
