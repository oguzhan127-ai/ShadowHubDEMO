local sections   = {}
local tabBtns    = {}
local activeTab  = nil

local function makeSection(name)
    local sf = Instance.new("ScrollingFrame")
    sf.Name = name
    sf.Size = UDim2.new(1, -10, 1, -8)
    sf.Position = UDim2.new(0, 5, 0, 4)
    sf.BackgroundTransparency = 1
    sf.CanvasSize = UDim2.new(0, 0, 0, 0)
    sf.ScrollBarThickness = isMobile and 0 or 3
    sf.ScrollBarImageColor3 = C.accent
    sf.VerticalScrollBarInset = Enum.ScrollBarInset.ScrollBar
    sf.ScrollingEnabled = true
    sf.ScrollingDirection = Enum.ScrollingDirection.Y
    sf.Visible = false
    sf.Parent = content
    local lay = Instance.new("UIListLayout", sf)
    lay.Padding = UDim.new(0, 7)
    lay.FillDirection = Enum.FillDirection.Vertical
    lay.HorizontalAlignment = Enum.HorizontalAlignment.Center
    lay.SortOrder = Enum.SortOrder.LayoutOrder
    Instance.new("UIPadding", sf).PaddingTop = UDim.new(0, 6)
    lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        sf.CanvasSize = UDim2.new(0, 0, 0, lay.AbsoluteContentSize.Y + 16)
    end)
    sections[name] = sf
    return sf
end

local function switchTab(name)
    if activeTab == name then return end
    if activeTab then
        if sections[activeTab] then sections[activeTab].Visible = false end
        if tabBtns[activeTab] then
            tw(tabBtns[activeTab].btn, 0.12, {BackgroundColor3 = C.sidebar})
            tabBtns[activeTab].ind.BackgroundTransparency = 1
            tw(tabBtns[activeTab].lbl, 0.12, {TextColor3 = C.sub})
        end
    end
    activeTab = name
    if sections[name] then sections[name].Visible = true end
    if tabBtns[name] then
        tw(tabBtns[name].btn, 0.12, {BackgroundColor3 = Color3.fromRGB(28, 16, 56)})
        tabBtns[name].ind.BackgroundTransparency = 0
        tw(tabBtns[name].lbl, 0.12, {TextColor3 = Color3.fromRGB(210, 175, 255)})
    end
end

