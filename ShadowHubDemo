    bg      = Color3.fromRGB(7, 6, 16),
    panel   = Color3.fromRGB(12, 10, 24),
    sidebar = Color3.fromRGB(10, 8, 20),
    accent  = Color3.fromRGB(110, 50, 255),
    accent2 = Color3.fromRGB(60, 180, 255),
    text    = Color3.fromRGB(225, 215, 255),
    sub     = Color3.fromRGB(150, 130, 200),
    danger  = Color3.fromRGB(220, 50, 100),
    swOff   = Color3.fromRGB(40, 30, 70),
    swOn    = Color3.fromRGB(110, 50, 255),
    stroke  = Color3.fromRGB(90, 55, 180),
    row     = Color3.fromRGB(11, 8, 22),
}

local function tw(obj, t, props)
    TweenService:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Quad), props):Play()
end

local function corner(obj, r)
    Instance.new("UICorner", obj).CornerRadius = UDim.new(0, r or 10)
end

local function stroke(obj, color, thick, trans)
    local s = Instance.new("UIStroke", obj)
    s.Color = color or C.stroke
    s.Thickness = thick or 1
    s.Transparency = trans or 0.5
    return s
end

