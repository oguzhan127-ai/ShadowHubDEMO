    -- "Lock" — big bold top label
    local lLblTop = Instance.new("TextLabel", lCard)
    lLblTop.Size               = UDim2.new(1, -20, 0, 26)
    lLblTop.Position           = UDim2.new(0, 18, 0, isMobile and 20 or 22)
    lLblTop.BackgroundTransparency = 1
    lLblTop.Text               = "Lock"
    lLblTop.Font               = Enum.Font.GothamBlack
    lLblTop.TextSize           = isMobile and 15 or 16
    lLblTop.TextColor3         = Color3.fromRGB(210, 185, 255)
