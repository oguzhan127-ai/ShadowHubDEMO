-- ANTI RAGDOLL + ANTI FLING
-- 5 layers:
-- 1. Heartbeat: force out of Physics state every frame → no ragdoll pose
-- 2. Heartbeat: zero AssemblyLinearVelocity when Physics state → no fling
-- 3. DescendantAdded: destroy BallSocketConstraints instantly → joints stay
-- 4. RagdollEndTime attribute: keep set to past → server thinks ragdoll ended
-- 5. RemoteEvent intercept: block Ragdoll remote from firing on client
-- Respawns cleanly via CharacterAdded
--------------------------------------------------------
local arOn    = false
local arConns = {}

local function enableAR()
    if arOn then return end
    arOn = true

    local function setup(char)
        if not char then return end
        local hum  = char:WaitForChild("Humanoid", 5)
        local root = char:WaitForChild("HumanoidRootPart", 5)
        local head = char:WaitForChild("Head", 5)
        if not hum or not root then return end
        local cam = workspace.CurrentCamera

        -- Layer 1 + 2: Heartbeat — fight Physics state, zero fling velocity,
        -- lock camera subject so it never follows the head
        local hbConn = RunService.Heartbeat:Connect(function()
            if not arOn then return end

            -- Force out of ragdoll state
            if hum:GetState() == Enum.HumanoidStateType.Physics then
                root.AssemblyLinearVelocity = Vector3.new(
                    0,
                    math.min(root.AssemblyLinearVelocity.Y, 50),
                    0
                )
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end

            -- Lock camera to Humanoid — prevents it from following head
            if cam and cam.CameraSubject ~= hum then
                cam.CameraSubject = hum
            end

            -- Keep RagdollEndTime in the past
            pcall(function()
                local t = workspace:GetServerTimeNow()
                if player:GetAttribute("RagdollEndTime") and
                   player:GetAttribute("RagdollEndTime") > t then
                    player:SetAttribute("RagdollEndTime", t - 10)
                end
            end)
        end)
        table.insert(arConns, hbConn)

        -- Layer 3: watch Motor6D joints — if the ragdoll system disables them
        -- (which detaches limbs/head), re-enable them immediately
        local function watchMotors()
            for _, d in ipairs(char:GetDescendants()) do
                if d:IsA("Motor6D") then
                    local mc = d:GetPropertyChangedSignal("Enabled"):Connect(function()
                        if not arOn then return end
                        if not d.Enabled then
                            d.Enabled = true
                        end
                    end)
                    table.insert(arConns, mc)
                end
            end
        end
        watchMotors()

        -- Also watch for new Motor6Ds added later
        local newMotorConn = char.DescendantAdded:Connect(function(d)
            if not arOn then return end
            if d:IsA("Motor6D") then
                local mc = d:GetPropertyChangedSignal("Enabled"):Connect(function()
                    if not arOn then return end
                    if not d.Enabled then
                        d.Enabled = true
                    end
                end)
                table.insert(arConns, mc)
            end
            -- Destroy ragdoll constraints added dynamically
            if d:IsA("BallSocketConstraint") or d:IsA("HingeConstraint") then
                task.defer(function()
                    if d and d.Parent and arOn then
                        d:Destroy()
                    end
                end)
            end
        end)
        table.insert(arConns, newMotorConn)
    end

    -- Layer 4: intercept Ragdoll RemoteEvent
    pcall(function()
        local pkgs   = game:GetService("ReplicatedStorage"):FindFirstChild("Packages")
        local folder = pkgs and pkgs:FindFirstChild("Ragdoll")
        local remote = folder and folder:FindFirstChild("Ragdoll")
        if remote and remote:IsA("RemoteEvent") then
            local rc = remote.OnClientEvent:Connect(function() end)
            table.insert(arConns, rc)
        end
    end)

    -- Layer 5: disable RagdollClient script
    pcall(function()
        for _, s in ipairs(player.PlayerScripts:GetChildren()) do
            if s.Name:lower():match("ragdollclient") then
                s.Disabled = true
            end
        end
    end)
    pcall(function()
        if getloadedmodules then
            for _, m in ipairs(getloadedmodules()) do
                local ok, name = pcall(function() return m.Name end)
                if ok and name:lower():match("ragdollclient") then
                    pcall(function() m.Disabled = true end)
                end
            end
        end
    end)

    setup(player.Character)

    local caConn = player.CharacterAdded:Connect(function(char)
        if arOn then setup(char) end
    end)
    table.insert(arConns, caConn)
end

local function disableAR()
    if not arOn then return end
    arOn = false
    for _, c in ipairs(arConns) do
        pcall(function() c:Disconnect() end)
    end
    arConns = {}
end

