-- SPEED BOOST + STEAL SPEED
-- Copied 1-1 from Savage Hub's SpeedCustomizer system.
-- Single Heartbeat, MoveDirection-based, WalkSpeed<25 = carrying.
-- sbOn = speed boost toggle, ssOn = steal speed toggle.
--------------------------------------------------------
local SPEED_VAL       = 43
local STEAL_SPEED_VAL = 30
local MAX_SPEED       = 500

local sbOn = false
local ssOn = false

local speedConn    = nil
local speedCharConn = nil

local speedChar = nil
local speedHRP  = nil
local speedHum  = nil

local function setupSpeedChar(char)
    speedChar = char
    speedHRP  = char:WaitForChild("HumanoidRootPart")
    speedHum  = char:WaitForChild("Humanoid")
end

local function startSpeedLoop()
    if speedConn then return end
    speedConn = RunService.Heartbeat:Connect(function()
        if not speedChar or not speedHRP or not speedHum then return end
        if not sbOn and not ssOn then return end

        local moveDir = speedHum.MoveDirection
        if moveDir.Magnitude <= 0 then return end

        -- Carry detection: WalkSpeed drops below 25 when carrying a brainrot
        local carrying = speedHum.WalkSpeed < 25

        local targetSpeed = nil
        if carrying and ssOn then
            targetSpeed = STEAL_SPEED_VAL
        elseif not carrying and sbOn then
            targetSpeed = SPEED_VAL
        end

        if not targetSpeed then return end

        targetSpeed = math.min(targetSpeed, MAX_SPEED)

        speedHRP.AssemblyLinearVelocity = Vector3.new(
            moveDir.X * targetSpeed,
            speedHRP.AssemblyLinearVelocity.Y,
            moveDir.Z * targetSpeed
        )
    end)
end

local function stopSpeedLoop()
    if speedConn then
        speedConn:Disconnect()
        speedConn = nil
    end
    pcall(function()
        if speedHRP then
            speedHRP.AssemblyLinearVelocity = Vector3.new(0, speedHRP.AssemblyLinearVelocity.Y, 0)
        end
    end)
end

local function enableSB()
    if sbOn then return end
    sbOn = true
    if player.Character then setupSpeedChar(player.Character) end
    if not speedCharConn then
        speedCharConn = player.CharacterAdded:Connect(setupSpeedChar)
    end
    startSpeedLoop()
end

local function disableSB()
    if not sbOn then return end
    sbOn = false
    if not ssOn then stopSpeedLoop() end
end

local function enableSS()
    if ssOn then return end
    ssOn = true
    if player.Character then setupSpeedChar(player.Character) end
    if not speedCharConn then
        speedCharConn = player.CharacterAdded:Connect(setupSpeedChar)
    end
    startSpeedLoop()
end

local function disableSS()
    if not ssOn then return end
    ssOn = false
    if not sbOn then stopSpeedLoop() end
end

