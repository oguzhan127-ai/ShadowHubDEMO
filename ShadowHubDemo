    -- Status dot — top right corner
    local lDot = Instance.new("Frame", lCard)
    lDot.Size             = UDim2.new(0, 9, 0, 9)
    lDot.Position         = UDim2.new(1, -16, 0, 9)
    lDot.BackgroundColor3 = Color3.fromRGB(65, 50, 95)
    lDot.BorderSizePixel  = 0
    lDot.ZIndex           = 5
