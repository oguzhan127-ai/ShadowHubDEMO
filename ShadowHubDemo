local function makeGui(name)
    local sg = Instance.new("ScreenGui")
    sg.Name = name
    sg.ResetOnSpawn = false
    sg.IgnoreGuiInset = true
    sg.DisplayOrder = 999
    local ok = false
    pcall(function() if gethui then sg.Parent = gethui(); ok = true end end)
    if not ok then pcall(function() sg.Parent = game:GetService("CoreGui"); ok = true end) end
    if not ok then sg.Parent = player:WaitForChild("PlayerGui") end
    return sg
end

