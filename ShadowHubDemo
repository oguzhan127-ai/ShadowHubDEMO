-- INFINITE JUMP
-- Bypass: invisible massless Part welded to HRootPart
-- BodyVelocity on the WELDED PART (not character)
-- Y-axis only, self-destructs after 0.1s
-- 3-way detection: Space / HumanoidState / Jump prop
--------------------------------------------------------
local ijOn   = false
local ijConn = nil
local ijPart = nil
local ijLast = 0
local IJ_POWER   = 42
local IJ_COOL    = 0.2

local function doJump()
    local char = player.Character
    if not char then return end
    local hum  = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    if tick() - ijLast < IJ_COOL then return end
    ijLast = tick()
    if not ijPart or not ijPart.Parent then
        ijPart = Instance.new("Part")
        ijPart.Size = Vector3.new(1,1,1)
        ijPart.Transparency = 1
        ijPart.Anchored = false
        ijPart.CanCollide = false
        ijPart.Massless = true
        ijPart.Parent = workspace
        local w = Instance.new("Weld")
        w.Part0 = root; w.Part1 = ijPart
        w.C0 = CFrame.new(0,0,0)
        w.Parent = ijPart
    end
    local bv = ijPart:FindFirstChild("IJB") or Instance.new("BodyVelocity")
    bv.Name = "IJB"
    bv.MaxForce = Vector3.new(0, math.huge, 0)
    bv.Velocity = Vector3.new(0, IJ_POWER, 0)
    bv.P = 5000
    bv.Parent = ijPart
    hum.Jump = true
    task.delay(0.1, function()
        if bv and bv.Parent then bv:Destroy() end
        if hum then hum.Jump = false end
    end)
end

local function enableIJ()
    if ijOn then return end
    ijOn = true
    ijConn = RunService.Heartbeat:Connect(function()
        local char = player.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space)
        or hum:GetState() == Enum.HumanoidStateType.Jumping
        or hum.Jump then
            doJump()
        end
    end)
end

local function disableIJ()
    if not ijOn then return end
    ijOn = false
    if ijConn then ijConn:Disconnect(); ijConn = nil end
    if ijPart then
        local bv = ijPart:FindFirstChild("IJB")
        if bv then bv:Destroy() end
        ijPart:Destroy(); ijPart = nil
    end
end

player.CharacterAdded:Connect(function()
    ijPart = nil
    if ijOn then disableIJ(); enableIJ() end
end)

--------------------------------------------------------
-- INSTANT GRAB SYSTEM
-- Copied 1-1 from doc16 old Shadow HUB
-- Sets HoldDuration=0 + MaxActivationDistance=huge on all prompts
-- Press E yourself once = instant grab, no hold wait
--------------------------------------------------------
local igOn     = false
local igThread = nil
local IG_DELAY = 0.5

local apOn          = false
local apAutoMode    = false  -- false=Manual, true=Auto
local apConn        = nil
local apHBConn      = nil
local apNearestName = "—"
local apNearestDist = 0
local promptCache   = {}
local cacheThread   = nil

local function rebuildCache()
    local list = {}
    pcall(function()
        local plots = workspace:FindFirstChild("Plots")
        if not plots then return end
        for _, plot in ipairs(plots:GetChildren()) do
            local pms = plot:FindFirstChild("AnimalPodiums")
            if not pms then continue end
            for _, pod in ipairs(pms:GetChildren()) do
                pcall(function()
                    local spawnPart = pod.Base.Spawn
                    local att       = spawnPart.PromptAttachment
                    for _, v in ipairs(att:GetChildren()) do
                        if v:IsA("ProximityPrompt") then
                            v.HoldDuration          = 0
                            v.MaxActivationDistance = math.huge
                            local name = pod.Name
                            pcall(function()
                                local oh = pod:FindFirstChild("AnimalOverhead", true)
                                local dn = oh and oh:FindFirstChild("DisplayName")
                                if dn and dn.Text ~= "" then name = dn.Text end
                            end)
                            table.insert(list, { prompt = v, part = spawnPart, name = name })
                        end
                    end
                end)
            end
        end
    end)
    promptCache = list
end

local function startCacheLoop()
    if cacheThread then return end
    cacheThread = task.spawn(function()
        while igOn or apOn do
            rebuildCache()
            task.wait(2)
        end
        cacheThread = nil
    end)
end

local function firePrompt(prompt)
    prompt.HoldDuration = 0
    pcall(function() fireproximityprompt(prompt) end)
    pcall(function() ProximityPromptSvc:FireProximityPrompt(prompt) end)
end

local function isBrainrotPrompt(prompt)
    local p = prompt.Parent
    while p and p ~= workspace do
        if p.Name == "AnimalPodiums" then return true end
        p = p.Parent
    end
    return false
end

-- INSTANT GRAB — doc16 exact: keeps HoldDuration=0 so pressing E is instant
local function enableIG()
    if igOn then return end
    igOn = true
    rebuildCache()
    startCacheLoop()
    igThread = task.spawn(function()
        while igOn do
            for _, d in ipairs(promptCache) do
                if d.prompt and d.prompt.Parent then
                    d.prompt.HoldDuration = 0
                end
            end
            task.wait(IG_DELAY)
        end
    end)
    if apAutoMode then enableAP() end
end

local function disableIG()
    igOn = false
    igThread = nil
end

-- AUTO PRESS — doc16 exact: fires on PromptShown + PromptButtonHoldBegan + Heartbeat
local function enableAP()
    if apOn then return end
    apOn = true

    local conn1 = ProximityPromptSvc.PromptShown:Connect(function(prompt)
        if apOn and isBrainrotPrompt(prompt) then firePrompt(prompt) end
    end)
    local conn2 = ProximityPromptSvc.PromptButtonHoldBegan:Connect(function(prompt)
        if apOn and isBrainrotPrompt(prompt) then firePrompt(prompt) end
    end)
    apConn = { Disconnect = function() conn1:Disconnect(); conn2:Disconnect() end }

    apHBConn = RunService.Heartbeat:Connect(function()
        if not apOn then return end
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local closest, closestDist = nil, math.huge
        for _, d in ipairs(promptCache) do
            if d.prompt and d.prompt.Parent and d.part and d.part.Parent then
                local dist = (d.part.Position - root.Position).Magnitude
