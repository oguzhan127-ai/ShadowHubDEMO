    local lHit = Instance.new("TextButton", lCard)
    lHit.Size               = UDim2.new(1, 0, 1, 0)
    lHit.BackgroundTransparency = 1
    lHit.Text               = ""
    lHit.AutoButtonColor    = false
    lHit.ZIndex             = 10

    -- Active state toggle — no glow, only dot + stroke + label colors
    local lActive = false
    local function setLockActive(v)
        lActive = v

        TweenService:Create(lDot, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            BackgroundColor3 = v
                and Color3.fromRGB(55, 220, 100)
                or  Color3.fromRGB(65, 50, 95)
        }):Play()
        TweenService:Create(lCardStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            Color        = v and Color3.fromRGB(70, 215, 110) or Color3.fromRGB(80, 40, 160),
            Transparency = v and 0.05 or 0.7
        }):Play()
        TweenService:Create(lLblTop, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {
            TextColor3 = v and Color3.fromRGB(130, 255, 175) or Color3.fromRGB(210, 185, 255)
        }):Play()
        TweenService:Create(lLblBot, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {
            TextColor3 = v and Color3.fromRGB(80, 210, 130) or Color3.fromRGB(140, 115, 195)
        }):Play()
        TweenService:Create(lAccBar, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {
            BackgroundColor3 = v and Color3.fromRGB(60, 220, 110) or Color3.fromRGB(130, 55, 255)
        }):Play()

        if v then enableAB() else disableAB() end
    end

    -- ============================================================
    -- CLICK + DRAG — bulletproof for both PC and Mobile
    -- Uses a simple pressed flag approach, no InputEnded comparison
    -- ============================================================
    local lPressed  = false
    local lDragging = false
    local lDragStart, lCardStart = nil, nil
    local L_DRAG_THRESH = 6

    lHit.InputBegan:Connect(function(inp)
        if inp.UserInputType ~= Enum.UserInputType.MouseButton1
        and inp.UserInputType ~= Enum.UserInputType.Touch then return end
        lPressed    = true
        lDragging   = false
        lDragStart  = Vector2.new(inp.Position.X, inp.Position.Y)
        lCardStart  = lCard.Position
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if not lPressed then return end
        if inp.UserInputType ~= Enum.UserInputType.MouseMovement
        and inp.UserInputType ~= Enum.UserInputType.Touch then return end
        if not lDragStart then return end
        local delta = Vector2.new(inp.Position.X, inp.Position.Y) - lDragStart
        if delta.Magnitude > L_DRAG_THRESH then
            lDragging = true
        end
        if lDragging then
            lCard.Position = UDim2.new(
                lCardStart.X.Scale, lCardStart.X.Offset + delta.X,
                lCardStart.Y.Scale, lCardStart.Y.Offset + delta.Y
            )
            lPosScaleX = lCard.Position.X.Scale
            lPosOffX   = lCard.Position.X.Offset
            lPosScaleY = lCard.Position.Y.Scale
            lPosOffY   = lCard.Position.Y.Offset
        end
    end)

    -- PC release
    lHit.InputEnded:Connect(function(inp)
        if inp.UserInputType ~= Enum.UserInputType.MouseButton1
        and inp.UserInputType ~= Enum.UserInputType.Touch then return end
        local wasDrag = lDragging
        lPressed  = false
        lDragging = false
        if not wasDrag then
            setLockActive(not lActive)
        end
    end)

    -- Slide-in: always from top, lands at last saved position
    local function slideInLock()
        local tx = lPosScaleX
        local txo = lPosOffX
        local ty = lPosScaleY
        local tyo = lPosOffY
        lCard.Position = UDim2.new(tx, txo, 0, -LBH - 20)
        TweenService:Create(lCard,
            TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
            {Position = UDim2.new(tx, txo, ty, tyo)}
        ):Play()
    end

    -- Reset position to default (called by Reset Config)
    local function resetLockPosition()
        lPosScaleX = LB_DEF_SX
        lPosOffX   = LB_DEF_OX
        lPosScaleY = LB_DEF_SY
        lPosOffY   = LB_DEF_OY
        lCard.Position = UDim2.new(lPosScaleX, lPosOffX, lPosScaleY, lPosOffY)
    end
    -- Store for reset button access and doClose
    toggleSetters._resetLockPos = resetLockPosition
    toggleSetters._lockSg = lockSg

    -- Expose current position for getData() in save config
    toggleSetters._getLockPos = function()
        return lPosScaleX, lPosOffX, lPosScaleY, lPosOffY
    end

    -- Toggle in Movement menu — shows/hides the floating card
    local abSwitch = makeSwitch(moveSection, "Lock", _cfgGet("lockOn", false), function(on)
        if on then
            lockSg.Enabled = true
            task.delay(0.05, slideInLock)
        else
            if lActive then setLockActive(false) end
            TweenService:Create(lCard,
                TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                {Position = UDim2.new(lCard.Position.X.Scale, lCard.Position.X.Offset, 0, -LBH - 20)}
            ):Play()
            task.delay(0.22, function()
                lockSg.Enabled = false
                lCard.Position = UDim2.new(lPosScaleX, lPosOffX, lPosScaleY, lPosOffY)
            end)
        end
    end)
    if _cfgGet("lockOn", false) then
        task.defer(function()
            lockSg.Enabled = true
            slideInLock()
        end)
    end
    toggleSetters.abOn   = function(v) abSwitch.set(v, true) end
    toggleSetters.lockOn = function(v) abSwitch.set(v, true) end

end

