        ColorSequenceKeypoint.new(0,   Color3.fromRGB(160, 60, 255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(110, 70, 255)),
        ColorSequenceKeypoint.new(1,   Color3.fromRGB(50,  140, 255)),
