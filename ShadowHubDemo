local sections   = {}
local tabBtns    = {}
local activeTab  = nil

local function makeSection(name)
    local sf = Instance.new("ScrollingFrame")
    sf.Name = name
    sf.Size = UDim2.new(1, -10, 1, -8)
    sf.Position = UDim2.new(0, 5, 0, 4)
    sf.BackgroundTransparency = 1
    sf.CanvasSize = UDim2.new(0, 0, 0, 0)
    sf.ScrollBarThickness = isMobile and 0 or 3
    sf.ScrollBarImageColor3 = C.accent
    sf.VerticalScrollBarInset = Enum.ScrollBarInset.ScrollBar
    sf.ScrollingEnabled = true
    sf.ScrollingDirection = Enum.ScrollingDirection.Y
    sf.Visible = false
    sf.Parent = content
    local lay = Instance.new("UIListLayout", sf)
    lay.Padding = UDim.new(0, 7)
    lay.FillDirection = Enum.FillDirection.Vertical
    lay.HorizontalAlignment = Enum.HorizontalAlignment.Center
    lay.SortOrder = Enum.SortOrder.LayoutOrder
    Instance.new("UIPadding", sf).PaddingTop = UDim.new(0, 6)
    lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        sf.CanvasSize = UDim2.new(0, 0, 0, lay.AbsoluteContentSize.Y + 16)
    end)
    sections[name] = sf
    return sf
end

-- Single shared indicator line that slides between tabs
local sharedInd = nil  -- created after sidebar exists

local function switchTab(name)
    if activeTab == name then return end
    if activeTab then
        if sections[activeTab] then sections[activeTab].Visible = false end
        if tabBtns[activeTab] then
            tw(tabBtns[activeTab].btn, 0.18, {BackgroundColor3 = C.sidebar})
            tw(tabBtns[activeTab].lbl, 0.18, {TextColor3 = C.sub})
            tw(tabBtns[activeTab].ico, 0.18, {TextColor3 = C.sub})
            local g = tabBtns[activeTab].btn:FindFirstChildOfClass("UIGradient")
            if g then g:Destroy() end
        end
    end
    activeTab = name
    if sections[name] then sections[name].Visible = true end
    if tabBtns[name] then
        tw(tabBtns[name].btn, 0.18, {BackgroundColor3 = Color3.fromRGB(22, 10, 50)})
        tw(tabBtns[name].lbl, 0.18, {TextColor3 = Color3.fromRGB(220, 190, 255)})
        tw(tabBtns[name].ico, 0.18, {TextColor3 = Color3.fromRGB(160, 80, 255)})
        local g = Instance.new("UIGradient", tabBtns[name].btn)
        g.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(35, 14, 80)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(12, 6,  28)),
        })
        g.Rotation = 135
        -- Animate shared indicator to new tab's position
        if sharedInd then
            task.spawn(function()
                task.wait()
                local btnAbs  = tabBtns[name].btn.AbsolutePosition
                local mainAbs = main.AbsolutePosition
                local btnH    = tabBtns[name].btn.AbsoluteSize.Y
                local indH    = sharedInd.AbsoluteSize.Y
                local newY    = (btnAbs.Y - mainAbs.Y) + math.floor((btnH - indH) / 2)
                local newX    = btnAbs.X - mainAbs.X  -- left edge of the button
                TweenService:Create(sharedInd,
                    TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
                    {Position = UDim2.new(0, newX, 0, newY)}
                ):Play()
            end)
        end
    end
end

