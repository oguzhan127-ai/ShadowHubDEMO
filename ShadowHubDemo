    lAccBar.Size             = UDim2.new(0, 3, 0.55, 0)
    lAccBar.Position         = UDim2.new(0, 8, 0.22, 0)
    lAccBar.BackgroundColor3 = Color3.fromRGB(130, 55, 255)
    lAccBar.BorderSizePixel  = 0
    lAccBar.ZIndex           = 4
