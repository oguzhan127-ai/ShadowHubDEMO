local function makeDuelBtn(icon, label, xAnchor)
    local glow = Instance.new("Frame")
    glow.Size             = UDim2.new(0, DBW + 12, 0, DBH + 12)
    glow.Position         = UDim2.new(xAnchor, -(DBW + 12)/2, 0, DBY - 6)
    glow.BackgroundColor3 = C.accent
    glow.BackgroundTransparency = 0.82
    glow.BorderSizePixel  = 0
    glow.ZIndex           = 1
    glow.Parent           = duelSg
    corner(glow, 18)

    local card = Instance.new("Frame")
    card.Size             = UDim2.new(0, DBW, 0, DBH)
    card.Position         = UDim2.new(xAnchor, -DBW/2, 0, DBY)
    card.BackgroundColor3 = Color3.fromRGB(9, 7, 20)
    card.BorderSizePixel  = 0
    card.ZIndex           = 2
    card.Parent           = duelSg
    corner(card, 14)
    local cardStroke = stroke(card, C.accent, 1.5, 0.55)

    local grad = Instance.new("UIGradient", card)
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(22, 12, 50)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(7,  5,  16)),
    })
    grad.Rotation = 135

    local iconLbl = Instance.new("TextLabel", card)
    iconLbl.Size               = UDim2.new(0, 28, 0, 28)
    iconLbl.Position           = UDim2.new(0, 10, 0.5, -14)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text               = icon
    iconLbl.Font               = Enum.Font.GothamBold
    iconLbl.TextSize           = isMobile and 18 or 20
    iconLbl.TextColor3         = C.accent
    iconLbl.ZIndex             = 3

    local nameLbl = Instance.new("TextLabel", card)
    nameLbl.Size               = UDim2.new(1, -48, 0, 18)
    nameLbl.Position           = UDim2.new(0, 44, 0, 8)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text               = label
    nameLbl.Font               = Enum.Font.GothamBold
    nameLbl.TextSize           = isMobile and 11 or 12
    nameLbl.TextColor3         = Color3.fromRGB(200, 175, 255)
    nameLbl.TextXAlignment     = Enum.TextXAlignment.Left
    nameLbl.ZIndex             = 3

    local statLbl = Instance.new("TextLabel", card)
    statLbl.Size               = UDim2.new(1, -48, 0, 16)
    statLbl.Position           = UDim2.new(0, 44, 1, -22)
    statLbl.BackgroundTransparency = 1
    statLbl.Text               = "READY"
    statLbl.Font               = Enum.Font.Gotham
    statLbl.TextSize           = isMobile and 9 or 10
    statLbl.TextColor3         = C.sub
    statLbl.TextXAlignment     = Enum.TextXAlignment.Left
    statLbl.ZIndex             = 3

    local barBG = Instance.new("Frame", card)
    barBG.Size             = UDim2.new(1, -20, 0, 3)
    barBG.Position         = UDim2.new(0, 10, 1, -7)
    barBG.BackgroundColor3 = Color3.fromRGB(30, 20, 60)
    barBG.BorderSizePixel  = 0
    barBG.ZIndex           = 3
    corner(barBG, 2)

    local barFill = Instance.new("Frame", barBG)
    barFill.Size             = UDim2.new(0, 0, 1, 0)
    barFill.BackgroundColor3 = C.accent
    barFill.BorderSizePixel  = 0
    barFill.ZIndex           = 4
    corner(barFill, 2)

    local hit = Instance.new("TextButton", card)
    hit.Size               = UDim2.new(1, 0, 1, 0)
    hit.BackgroundTransparency = 1
    hit.Text               = ""
    hit.ZIndex             = 10

    local dragging, dragStart, cardStart, glowStart = false, nil, nil, nil
    local hasDragged, touchId = false, nil
    local DRAG_THRESH = 6

    hit.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging  = true; hasDragged = false; touchId = inp
            dragStart = Vector2.new(inp.Position.X, inp.Position.Y)
            cardStart = card.Position
            glowStart = glow.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if not dragging then return end
        if inp.UserInputType ~= Enum.UserInputType.MouseMovement
        and inp.UserInputType ~= Enum.UserInputType.Touch then return end
        local delta = Vector2.new(inp.Position.X, inp.Position.Y) - dragStart
        if delta.Magnitude > DRAG_THRESH then hasDragged = true end
        if hasDragged then
            card.Position = UDim2.new(cardStart.X.Scale, cardStart.X.Offset + delta.X,
                                      cardStart.Y.Scale, cardStart.Y.Offset + delta.Y)
            glow.Position = UDim2.new(glowStart.X.Scale, glowStart.X.Offset + delta.X,
                                      glowStart.Y.Scale, glowStart.Y.Offset + delta.Y)
        end
    end)
    hit.InputEnded:Connect(function(inp)
        if inp == touchId then dragging = false end
    end)

    local barTween = nil
    local function setOn(on, status)
        TweenService:Create(card, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            BackgroundColor3 = on and Color3.fromRGB(16, 8, 38) or Color3.fromRGB(9, 7, 20)
        }):Play()
        TweenService:Create(cardStroke, TweenInfo.new(0.2), {
            Color       = on and Color3.fromRGB(140, 80, 255) or C.accent,
            Transparency = on and 0 or 0.55
        }):Play()
        TweenService:Create(glow, TweenInfo.new(0.2), {
            BackgroundTransparency = on and 0.55 or 0.82
        }):Play()
        TweenService:Create(iconLbl, TweenInfo.new(0.15, Enum.EasingStyle.Back), {
            TextColor3 = on and Color3.fromRGB(180, 120, 255) or C.accent
        }):Play()
        statLbl.TextColor3 = on and Color3.fromRGB(140, 220, 140) or C.sub
        statLbl.Text       = status or (on and "RUNNING..." or "READY")
        if barTween then barTween:Cancel() end
        if on then
            barFill.Size = UDim2.new(0, 0, 1, 0)
            barFill.BackgroundColor3 = Color3.fromRGB(110, 50, 255)
            barTween = TweenService:Create(barFill,
                TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                {Size = UDim2.new(0.9, 0, 1, 0)})
            barTween:Play()
        else
            barTween = TweenService:Create(barFill,
                TweenInfo.new(0.2, Enum.EasingStyle.Quad),
                {Size = UDim2.new(0, 0, 1, 0)})
            barTween:Play()
        end
    end

    local function slideIn()
        card.Position = UDim2.new(card.Position.X.Scale, card.Position.X.Offset, 0, -DBH - 20)
        glow.Position = UDim2.new(glow.Position.X.Scale, glow.Position.X.Offset, 0, -DBH - 26)
        TweenService:Create(card, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
            {Position = UDim2.new(card.Position.X.Scale, card.Position.X.Offset, 0, DBY)}):Play()
        TweenService:Create(glow, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
            {Position = UDim2.new(glow.Position.X.Scale, glow.Position.X.Offset, 0, DBY - 6)}):Play()
    end

    return hit, setOn, slideIn, statLbl, function() return hasDragged end
end

local leftHit,  setLeftOn,  slideLeft,  leftStat,  leftDragged  = makeDuelBtn("←", "AUTO LEFT",  0.28)
local rightHit, setRightOn, slideRight, rightStat, rightDragged = makeDuelBtn("→", "AUTO RIGHT", 0.72)

duelSg:GetPropertyChangedSignal("Enabled"):Connect(function()
    if duelSg.Enabled then
        task.delay(0.05, slideLeft)
        task.delay(0.12, slideRight)
    end
end)

leftHit.MouseButton1Click:Connect(function()
    if leftDragged() then return end
    auto1 = not auto1
    setLeftOn(auto1)
    if auto1 then
        auto2 = false; setRightOn(false)
        task.spawn(function()
            setLeftOn(true, "Going...")
            go(A1_P1, SPEED_IDA, function() return auto1 end)
            if not auto1 then return end

            setLeftOn(true, "Stealing ⚡")
            go(A1_P2, SPEED_IDA, function() return auto1 end)
            if not auto1 then return end

            instaGrab = true

            setLeftOn(true, "Returning...")
            go(A1_P3, SPEED_VOLTA, function() return auto1 end)
            if not auto1 then instaGrab = false; return end

            instaGrab = false

            go(A1_P4, SPEED_VOLTA, function() return auto1 end)

            auto1 = false
            setLeftOn(false, "DONE ✓")
            task.delay(1, function() setLeftOn(false) end)
        end)
    end
end)

rightHit.MouseButton1Click:Connect(function()
    if rightDragged() then return end
    auto2 = not auto2
    setRightOn(auto2)
    if auto2 then
        auto1 = false; setLeftOn(false)
        task.spawn(function()
            setRightOn(true, "Going...")
            go(B1, SPEED_IDA, function() return auto2 end)
            if not auto2 then return end

            setRightOn(true, "Stealing ⚡")
            go(B2, SPEED_IDA, function() return auto2 end)
            if not auto2 then return end

            instaGrab = true

            setRightOn(true, "Returning...")
            go(B3, SPEED_VOLTA, function() return auto2 end)
            if not auto2 then instaGrab = false; return end

            instaGrab = false

            go(B4, SPEED_VOLTA, function() return auto2 end)

            auto2 = false
            setRightOn(false, "DONE ✓")
            task.delay(1, function() setRightOn(false) end)
        end)
    end
end)

local autoplaySwitch = makeSwitch(duelsSection, "Autoplay", _cfgGet("autoplayOn", false), function(on)
    autoplayOn = on
    duelSg.Enabled = on
    if not on then
        auto1 = false; setLeftOn(false)
        auto2 = false; setRightOn(false)
        instaGrab = false
    end
end)

makeLabel(duelsSection, "Auto Left / Right buttons appear at top of screen.")

if _cfgGet("autoplayOn", false) then
    task.defer(function()
        autoplayOn = true
        duelSg.Enabled = true
        autoplaySwitch.set(true, true)
    end)
end

-- MINIMIZE / CLOSE
--------------------------------------------------------
local minimized = false

local function doMinimize()
    minimized = not minimized
    TweenService:Create(main, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
        Size = UDim2.new(0, FW, 0, minimized and 44 or FH)
    }):Play()
    sidebar.Visible     = not minimized
    content.Visible     = not minimized
    minimizeBtn.Text    = minimized and "+" or "−"
end

local function doClose()
    disableIJ()
    disableAR()
    disableSB()
    disableSS()
    disableIG()
    disableAP()
    auto1 = false
    auto2 = false
    instaGrab = false
    TweenService:Create(main, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0.5, 0),
    }):Play()
    task.delay(0.3, function()
        -- Destroy all HUDs
        if sg     and sg.Parent     then sg:Destroy() end
        if duelSg and duelSg.Parent then duelSg:Destroy() end
        -- Lock button — stored reference
        local lsg = toggleSetters._lockSg
        if lsg and lsg.Parent then lsg:Destroy() end
        -- Drop button
        local dsg = toggleSetters._dropSg
        if dsg and dsg.Parent then dsg:Destroy() end
    end)
end

minimizeBtn.MouseButton1Click:Connect(doMinimize)
closeBtn.MouseButton1Click:Connect(doClose)
