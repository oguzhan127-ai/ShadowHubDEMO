local function rebuildCache()
    local list = {}
    pcall(function()
        local plots = workspace:FindFirstChild("Plots")
        if not plots then return end
        for _, plot in ipairs(plots:GetChildren()) do
            local pms = plot:FindFirstChild("AnimalPodiums")
            if not pms then continue end
            for _, pod in ipairs(pms:GetChildren()) do
                pcall(function()
                    local spawnPart = pod.Base.Spawn
                    local att       = spawnPart.PromptAttachment
                    for _, v in ipairs(att:GetChildren()) do
                        if v:IsA("ProximityPrompt") then
