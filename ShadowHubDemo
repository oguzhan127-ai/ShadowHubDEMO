    local dragging, dragStart, frameStart, touchId = false, nil, nil, nil

    local dragHandle = Instance.new("TextButton")
    dragHandle.Size = UDim2.new(1, -100, 1, 0)
    dragHandle.BackgroundTransparency = 1
    dragHandle.Text = ""
    dragHandle.AutoButtonColor = false
    dragHandle.ZIndex = 1
    dragHandle.Active = true
    dragHandle.Parent = topbar

    dragHandle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch then
            dragging = true; touchId = i
            dragStart = Vector2.new(i.Position.X, i.Position.Y)
            -- Use AbsolutePosition — this is always the real screen position
            frameStart = Vector2.new(main.AbsolutePosition.X, main.AbsolutePosition.Y)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if not dragging or i ~= touchId then return end
        local d = Vector2.new(i.Position.X, i.Position.Y) - dragStart
        main.Position = UDim2.new(0, frameStart.X + d.X, 0, frameStart.Y + d.Y)
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i == touchId then dragging = false; touchId = nil end
    end)
end

