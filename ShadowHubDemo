        local front = targetHRP.Position + targetHRP.CFrame.LookVector * 1.5
        local dir   = Vector3.new(
            front.X - root.Position.X,
            0,
            front.Z - root.Position.Z
        )
        if dir.Magnitude < 0.1 then return end
        root.AssemblyLinearVelocity = Vector3.new(
            dir.Unit.X * 56.5,
            root.AssemblyLinearVelocity.Y,
            dir.Unit.Z * 56.5
        )
    end

    local abTarget = nil
    local abRepick = 0

    local function enableAB()
        if abOn then return end
        abOn    = true
        abTarget = pickTarget()
        abRepick = 0

        abConn = RunService.Heartbeat:Connect(function()
            if not abOn then return end
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not root then return end

            abRepick += 1
            if abRepick >= 120 or not abTarget or not abTarget.Character
            or not abTarget.Character:FindFirstChild("HumanoidRootPart") then
                abTarget = pickTarget()
                abRepick = 0
            end
            if not abTarget then return end

            local targetRoot = abTarget.Character:FindFirstChild("HumanoidRootPart")
            if not targetRoot then return end

            flyToFront(targetRoot)
        end)

        abCharConn = player.CharacterAdded:Connect(function()
            task.wait(0.5)
            if abOn then abTarget = pickTarget() end
        end)
    end

    local function disableAB()
        abOn    = false
        abTarget = nil
        if abConn     then abConn:Disconnect();     abConn     = nil end
        if abCharConn then abCharConn:Disconnect(); abCharConn = nil end
    end

