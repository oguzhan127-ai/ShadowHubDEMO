    sbOn = false
    if not ssOn then stopSpeedLoop() end
end

local function enableSS()
    if ssOn then return end
    ssOn = true
    if player.Character then setupSpeedChar(player.Character) end
    if not speedCharConn then
        speedCharConn = player.CharacterAdded:Connect(setupSpeedChar)
    end
    startSpeedLoop()
end

