-- FALLING DOTS — task.delay loop, no Heartbeat, no event leaks
task.spawn(function()
    local DOT_COUNT = 16
    local overlay = Instance.new("Frame")
    overlay.Size = UDim2.new(1, 0, 1, 0)
    overlay.BackgroundTransparency = 1
    overlay.BorderSizePixel = 0
    overlay.ZIndex = 3
    overlay.ClipsDescendants = true
    overlay.Active = false
    overlay.Parent = main

    local function loopDot(dot)
        task.spawn(function()
            while dot and dot.Parent do
                local x   = math.random(2, 98) / 100
                local dur = math.random(5, 12)
                local alpha = math.random(20, 55) / 100
                dot.BackgroundTransparency = alpha
                dot.Position = UDim2.new(x, 0, -0.04, 0)
                TweenService:Create(dot,
                    TweenInfo.new(dur, Enum.EasingStyle.Linear),
                    {Position = UDim2.new(x, 0, 1.04, 0)}
                ):Play()
                task.wait(dur)
            end
        end)
    end

    for i = 1, DOT_COUNT do
        local size = math.random(2, 4)
        local dot = Instance.new("Frame")
        dot.Size = UDim2.new(0, size, 0, size)
        dot.BorderSizePixel = 0
        dot.ZIndex = 4
        dot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        dot.BackgroundTransparency = 0.5
        -- Spread initial Y so they don't all start from top
        dot.Position = UDim2.new(math.random(2,98)/100, 0, math.random(0,100)/100, 0)
        Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
        dot.Parent = overlay
        -- Stagger starts
        task.delay(i * 0.5, function()
            loopDot(dot)
        end)
    end
end)


